#include <stdio.h>

int main() {
    int marks[6] = {45, 60, 38, 52, 47, 55};
    int *p = marks;
    int i, highest = 0;

    printf("Original marks: ");
    for (i = 0; i < 6; i++)
        printf("%d ", *(p + i));
    printf("\n");

    for (i = 0; i < 6; i++)
        if (*(p + i) > highest)
            highest = *(p + i);

    printf("Highest mark: %d\n", highest);


    for (i = 0; i < 6; i++)
        *(p + i) = (int)(((float)*(p + i) / highest) * 100);

    printf("Scaled marks : ");
    for (i = 0; i < 6; i++)
        printf("%d ", *(p + i));
    printf("\n");

    return 0;
}
