#include <stdio.h>

int main() {
    void *sensor;

    int vibration = 847;
    float temperature = 73.6;
    char status = 'W';

    sensor = &vibration;
    int v = *(int *)sensor;
    printf("Vibration  : %d\n", v);
    printf("Address    : %p\n\n", (void *)sensor);

    sensor = &temperature;
    float t = *(float *)sensor;
    printf("Temperature: %.1f C\n", t);
    printf("Address    : %p\n\n", (void *)sensor);

    sensor = &status;
    char s = *(char *)sensor;
    printf("Status     : %c\n", s);
    printf("Address    : %p\n\n", (void *)sensor);

    if (s == 'N')
        printf("Alert: Normal operation.\n");
    else if (s == 'W')
        printf("Alert: Warning! Check the system.\n");
    else if (s == 'C')
        printf("Alert: CRITICAL! Immediate action required.\n");

    return 0;
}
