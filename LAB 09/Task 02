#include <stdio.h>

float applyDiscount(float price, int tier) {
    if (tier == 1)       return price - (price * 0.05);
    else if (tier == 2)  return price - (price * 0.10);
    else if (tier == 3)  return price - (price * 0.20);
    else if (tier == 4)  return price - (price * 0.30);
    else                 return price;
}

void printInvoice(float original, float discounted) {
    float discount = original - discounted;
    float delivery = 0;
    float total;

    if (discounted < 2000)
        delivery = 150;

    total = discounted + delivery;

    printf("\n--- Invoice ---\n");
    printf("Original Price : Rs. %.2f\n", original);
    printf("Discount       : Rs. %.2f\n", discount);
    printf("After Discount : Rs. %.2f\n", discounted);
    if (delivery > 0)
        printf("Delivery Charge: Rs. %.2f\n", delivery);
    printf("Total Payable  : Rs. %.2f\n", total);
}

int main() {
    float price, discounted;
    int tier;

    printf("Enter original price: ");
    scanf("%f", &price);
    printf("Enter tier (1=Bronze, 2=Silver, 3=Gold, 4=Platinum): ");
    scanf("%d", &tier);

    discounted = applyDiscount(price, tier);
    printInvoice(price, discounted);

    return 0;
}
