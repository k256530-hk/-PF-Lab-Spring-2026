#include <stdio.h>

int main() {
    int balance, usage;

    printf("Enter available data balance (in MB): ");
    scanf("%d", &balance);

    while(balance > 0) {
        printf("Enter data usage (in MB): ");
        scanf("%d", &usage);

        balance = balance - usage;

        printf("Remaining balance: %d MB\n", balance);
    }

    printf("Data balance exhausted!\n");

    return 0;
}
