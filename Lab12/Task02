#include <stdio.h>
#include <stdlib.h>

int main() {
    
    int *contacts = (int *)malloc(3 * sizeof(int));
    if (contacts == NULL) {
        printf("Initial malloc failed!\n");
        return 1;
    }

    printf("Enter 3 contact IDs:\n");
    for (int i = 0; i < 3; i++) {
        printf("Contact %d ID: ", i + 1);
        scanf("%d", &contacts[i]);
    }

    int *temp = (int *)realloc(contacts, 5 * sizeof(int));

    // (c) NULL check for realloc failure
    if (temp == NULL) {
      
        printf("realloc failed! Original data preserved.\n");
        free(contacts);     
        contacts = NULL;     
        return 1;
    }

    contacts = temp; 

    printf("\nEnter 2 more contact IDs:\n");
    for (int i = 3; i < 5; i++) {
        printf("Contact %d ID: ", i + 1);
        scanf("%d", &contacts[i]);
    }

    printf("\n--- All 5 Contacts ---\n");
    for (int i = 0; i < 5; i++) {
        printf("Contact %d ID: %d\n", i + 1, contacts[i]);
    }

    free(contacts);
    contacts = NULL; 

    return 0;
}
