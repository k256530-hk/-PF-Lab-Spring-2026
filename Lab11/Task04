#include <stdio.h>
#include <string.h>

struct Patient {
    char name[50];
    int age;
    char bloodType[5];
    int patientID;
    char diagnosis[100];
};

void displayAll(struct Patient p[], int n) {
    printf("%s %s %s %s %s\n", "ID", "Name", "Age", "Blood", "Diagnosis");
    printf("-----------------------------------------------------------------------\n");
    for (int i = 0; i < n; i++) {
        printf("%d %s %d %s %s \n",
               p[i].patientID, p[i].name, p[i].age, p[i].bloodType, p[i].diagnosis);
    }
}

void searchByID(struct Patient p[], int n, int id) {
    for (int i = 0; i < n; i++) {
        if (p[i].patientID == id) {
            printf("Found: %s | Age: %d | Blood: %s | Diagnosis: %s\n",
                   p[i].name, p[i].age, p[i].bloodType, p[i].diagnosis);
            return;
        }
    }
    printf("Patient not found\n");
}

int main() {
    struct Patient p[5];
    for (int i = 0; i < 5; i++) {
        printf("\nEnter details for patient %d:\n", i + 1);

        printf("Patient ID: ");
        scanf("%d", &p[i].patientID);

        printf("Age: ");
        scanf("%d", &p[i].age);

        printf("Blood Type: ");
        scanf("%s", p[i].bloodType);

        while (getchar() != '\n');
        printf("Name: ");
        fgets(p[i].name, 50, stdin);
        p[i].name[strcspn(p[i].name, "\n")] = '\0';

        printf("Diagnosis: ");
        fgets(p[i].diagnosis, 100, stdin);
        p[i].diagnosis[strcspn(p[i].diagnosis, "\n")] = '\0';
    }

    displayAll(p, 5);

    int id;
    printf("\nEnter ID to search: ");
    scanf("%d", &id);
    searchByID(p, 5, id);
    return 0;
}
