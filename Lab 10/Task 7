#include <stdio.h>
#include <string.h>

char invProducts[10][50];
int invQuantities[10];
int invCount = 0;

void displayInventory() {
    printf("\n--- Full Inventory ---\n");
    for (int i = 0; i < invCount; i++) {
        printf("Product: %s | Quantity: %d\n", invProducts[i], invQuantities[i]);
    }
}

int main() {
  
    printf("=== Run 1 ===\n");
    printf("Enter product name: ");
    scanf("%49s", invProducts[invCount]);
    printf("Enter quantity: ");
    scanf("%d", &invQuantities[invCount]);
    invCount++;
    printf("Entry added to inventory.txt (simulated)\n");
    displayInventory();


    printf("\n=== Run 2 ===\n");
    printf("Enter product name: ");
    scanf("%49s", invProducts[invCount]);
    printf("Enter quantity: ");
    scanf("%d", &invQuantities[invCount]);
    invCount++;
    printf("Entry added to inventory.txt (simulated)\n");
    displayInventory();

    return 0;
}
