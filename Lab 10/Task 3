#include <stdio.h>
#include <string.h>

int main() {
    char email[50];
    char copy[50];
    char display[50];

    printf("Enter email address: ");
    fgets(email, sizeof(email), stdin);


    int len = strlen(email);
    if (len > 0 && email[len - 1] == '\n')
        email[--len] = '\0';

    strcpy(copy, email);

    
    char *at = strchr(copy, '@');
    if (at == NULL) {
        printf("Error: No '@' symbol found in email.\n");
        return 1;
    }

 
    char *domain = at + 1;
    printf("Domain: %s\n", domain);

   
    if (strstr(domain, ".") == NULL) {
        printf("Warning: Domain does not contain a '.' separator.\n");
    } else {
        printf("Domain is valid (contains '.').\n");
    }

  
    strcpy(display, "Email: ");
    strcat(display, email);
    printf("%s\n", display);

   
    printf("Email length: %lu\n", strlen(email));

    return 0;
}
